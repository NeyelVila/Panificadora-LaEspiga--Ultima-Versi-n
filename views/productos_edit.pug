extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Editar Producto
    a.btn.btn-outline-secondary(href="/productos/view") Volver al Catálogo

  .card.shadow-sm.mx-auto(style="max-width: 600px;")
    .card-body
      form(action=`/productos/actualizar-web/${producto._id}` method="POST")
        
        .mb-3
          label.form-label.fw-bold(for="nombre") Nombre del Producto
          input#nombre.form-control(type="text" name="nombre" value=producto.nombre required)
        
        .mb-4
          label.form-label.fw-bold(for="precio") Precio Unitario ($)
          .input-group
            span.input-group-text $
            input#precio.form-control(type="number" name="precio" value=producto.precio min="0" step="0.01" required)
              
        button.btn.btn-primary.w-100.btn-lg(type="submit") 
          i.bi.bi-save.me-2
          | Guardar Cambios