extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Receta: #{producto.nombre}
    a.btn.btn-outline-secondary(href="/productos/view") Volver al Catálogo

  if receta
    .card.shadow-sm
      .card-body
        h5 Ingredientes necesarios:
        ul.list-group.mt-3
          each ing in receta.ingredientes
            li.list-group-item.d-flex.justify-content-between.align-items-center
              span #{ing.insumoId.nombre}
              span.badge.bg-primary.rounded-pill #{ing.cantidad} #{ing.insumoId.unidad}
  else
    .alert.alert-warning.shadow-sm
      h4.alert-heading 
        i.bi.bi-exclamation-triangle.me-2
        | Receta no encontrada
      p Este producto todavía no tiene una receta configurada en el sistema. Sin una receta, el sistema no podrá descontar insumos del inventario cuando se produzca.
      hr
      a.btn.btn-warning(href=`/productos/${producto._id}/nueva-receta`)
        i.bi.bi-plus-circle.me-1
        | Cargar Receta Ahora