extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Registrar Nuevo Insumo
    a.btn.btn-outline-secondary(href="/insumos/view") Cancelar

  .card.shadow-sm(style="max-width: 600px;")
    .card-body
      form(action="/insumos/crear-web" method="POST")
        .mb-3
          label.form-label Nombre de la Materia Prima
          input.form-control(type="text" name="nombre" required placeholder="Ej: Azúcar Chango")
        
        .row.mb-3
          .col-md-6
            label.form-label Unidad de Medida
            select.form-select(name="unidad" required)
              option(value="") Elegir...
              option(value="kg") Kilogramos (kg)
              option(value="gr") Gramos (gr)
              option(value="L") Litros (L)
              option(value="ml") Mililitros (ml)
              option(value="unidades") Unidades
          
          .col-md-6
            label.form-label Stock Mínimo (Alerta)
            input.form-control(type="number" step="0.01" name="stockMinimo" required)
        
        .mb-4
          label.form-label Stock Inicial
          input.form-control(type="number" step="0.01" name="stockActual" required)

        button.btn.btn-primary.w-100(type="submit") Guardar Insumo