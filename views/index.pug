extends layout

block content
  h1.mb-4 Bienvenido al Panel de Control
  p.text-muted Gestión operativa de La Espiga de Oro

  .row.mt-4
    //- Tarjeta: Clientes
    .col-md-4
      .card.text-bg-primary.mb-3.shadow-sm
        .card-body
          h5.card-title 
            i.bi.bi-people-fill.me-2 
            | Clientes Activos
          p.card-text.display-4.fw-bold #{clientesActivos || 0}
          //- ¡Enlace actualizado!
          a.btn.btn-light.btn-sm.mt-2(href="/clientes/view") Administrar clientes
          
    //- Tarjeta: Pedidos
    .col-md-4
      .card.text-bg-success.mb-3.shadow-sm
        .card-body
          h5.card-title 
            i.bi.bi-receipt.me-2
            | Pedidos Totales
          p.card-text.display-4.fw-bold #{pedidosMes || 0}
          //- ¡Enlace actualizado!
          a.btn.btn-light.btn-sm.mt-2(href="/pedidos/view") Ver pedidos
          
    //- Tarjeta: Alertas de Stock (Color dinámico)
    .col-md-4
      //- Lógica: Si hay más de 0 alertas, fondo rojo. Si no, fondo gris.
      .card.mb-3.shadow-sm(class=(alertasStock > 0 ? 'text-bg-danger' : 'text-bg-secondary'))
        .card-body
          h5.card-title 
            i.bi.bi-exclamation-triangle-fill.me-2
            | Alertas de Stock
          p.card-text.display-4.fw-bold #{alertasStock || 0}
          //- ¡Enlace actualizado!
          a.btn.btn-light.btn-sm.mt-2(href="/insumos/view") Revisar inventario