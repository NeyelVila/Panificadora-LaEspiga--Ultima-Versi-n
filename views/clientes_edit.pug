extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Editar Cliente
    a.btn.btn-outline-secondary(href="/clientes/view") Cancelar

  .card.shadow-sm
    .card-body
      form(action=`/clientes/actualizar/${cliente._id}` method="POST")
        .mb-3
          label.form-label(for="nombre") Nombre completo o Razón Social
          input#nombre.form-control(type="text" name="nombre" value=cliente.nombre required)
        
        .row.mb-3
          .col-md-6
            label.form-label(for="email") Correo Electrónico
            input#email.form-control(type="email" name="email" value=cliente.email required)
          .col-md-6
            label.form-label(for="telefono") Teléfono
            input#telefono.form-control(type="text" name="telefono" value=cliente.telefono required)
            
        .row.mb-4
          .col-md-8
            label.form-label(for="direccion") Dirección
            input#direccion.form-control(type="text" name="direccion" value=cliente.direccion required)
          .col-md-4
            label.form-label(for="tipo") Tipo de Cliente
            select#tipo.form-select(name="tipo" required)
              option(value="minorista" selected=(cliente.tipo === 'minorista')) Minorista
              option(value="mayorista" selected=(cliente.tipo === 'mayorista')) Mayorista
              option(value="franquicia" selected=(cliente.tipo === 'franquicia')) Franquicia
              
        button.btn.btn-success.w-100.btn-lg(type="submit") Actualizar Datos del Cliente