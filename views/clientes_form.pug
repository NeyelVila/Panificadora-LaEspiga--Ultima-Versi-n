extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Nuevo Cliente
    a.btn.btn-outline-secondary(href="/clientes/view") Volver al listado

  .card.shadow-sm
    .card-body
      form(action="/clientes/crear" method="POST")
        .mb-3
          label.form-label(for="nombre") Nombre completo o Razón Social
          input#nombre.form-control(type="text" name="nombre" required placeholder="Ej. Juan Pérez o Panadería El Sol")
        
        .row.mb-3
          .col-md-6
            label.form-label(for="email") Correo Electrónico
            input#email.form-control(type="email" name="email" required placeholder="ejemplo@correo.com")
          .col-md-6
            label.form-label(for="telefono") Teléfono
            input#telefono.form-control(type="text" name="telefono" required placeholder="Solo números")
            
        .row.mb-4
          .col-md-8
            label.form-label(for="direccion") Dirección
            input#direccion.form-control(type="text" name="direccion" required placeholder="Calle y número")
          .col-md-4
            label.form-label(for="tipo") Tipo de Cliente
            select#tipo.form-select(name="tipo" required)
              option(value="minorista") Minorista
              option(value="mayorista") Mayorista
              option(value="franquicia") Franquicia
              
        button.btn.btn-primary.w-100.btn-lg(type="submit") Guardar Cliente