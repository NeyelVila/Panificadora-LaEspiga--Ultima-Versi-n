doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title La Espiga de Oro - Sistema de Gestión
    //- Usaremos Bootstrap para que se vea bien rápido
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
    style.
      .sidebar { min-height: 100vh; background: #4b3621; color: white; }
      .sidebar a { color: #d2b48c; text-decoration: none; display: block; padding: 15px; }
      .sidebar a:hover { background: #5d4037; color: white; }
      .nav-active { background: #5d4037; font-weight: bold; }
  
  body
    .container-fluid
      .row
        //- Sidebar (Menú Lateral)
        .col-md-2.p-0.sidebar
          .p-4.text-center
            h4 🥖 La Espiga
            hr
          nav
            a(href="/") 
              i.bi.bi-house-door.me-2
              | Dashboard
            a(href="/productos/view") 
              i.bi.bi-box-seam.me-2
              | Productos
            a(href="/pedidos/view") 
              i.bi.bi-cart-check.me-2
              | Pedidos
            a(href="/insumos/view") 
              i.bi.bi-moisture.me-2
              | Stock de Insumos
            a(href="/facturacion/view") 
              i.bi.bi-file-earmark-spreadsheet.me-2
              | Facturación
        
        //- Contenido Principal
        .col-md-10.p-4.bg-light(id="app-content")
          block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="/js/navegacion-fetch.js")
