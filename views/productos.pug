extends layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Catálogo de Productos
    a.btn.btn-primary(href="/productos/nuevo") 
      i.bi.bi-plus-lg.me-1
      | Nuevo Producto

  .card.shadow-sm
    .card-body
      if productos && productos.length > 0
        table.table.table-hover.align-middle
          thead.table-dark
            tr
              th Nombre del Producto
              th Precio Unitario
              th.text-center Stock Excedente
              th.text-center Total Entregado
              th.text-center Acciones
          tbody
            each producto in productos
              tr
                td.fw-bold= producto.nombre
                td.text-success.fw-bold $ #{producto.precio}
                td.text-center
                  if producto.stockExcedente > 0
                    span.badge.bg-warning.text-dark.fs-6 #{producto.stockExcedente} uds
                  else
                    span.text-muted -
                td.text-center
                  span.badge.bg-info.text-dark.fs-6 #{producto.totalEntregado || 0} uds
                td.text-center
                  .d-flex.gap-1.justify-content-center
                    a.btn.btn-sm.btn-outline-warning(href=`/productos/${producto._id}/receta` title="Ver Receta")
                      i.bi.bi-journal-text
                    a.btn.btn-sm.btn-outline-primary(href=`/productos/editar-web/${producto._id}` title="Modificar Precio")
                      i.bi.bi-pencil
                    form(action=`/productos/baja-web/${producto._id}` method="POST" class="d-inline mb-0")
                      button.btn.btn-sm.btn-outline-danger(type="submit" onclick="return confirm('¿Seguro?');")
                        i.bi.bi-trash
      else
        .alert.alert-info.mb-0 
          i.bi.bi-info-circle.me-2
          | No hay productos registrados.